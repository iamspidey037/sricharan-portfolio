# .env.example
# Copy this file to .env.local and fill in ALL values before running the app.
# NEVER commit .env.local to Git.

# ═══════════════════════════════════════════════════════════════
# DATABASE — MongoDB Atlas
# ═══════════════════════════════════════════════════════════════

# Get this from MongoDB Atlas → Connect → Connect your application
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# ═══════════════════════════════════════════════════════════════
# JWT SECRETS — Generate strong random secrets (32+ chars)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ═══════════════════════════════════════════════════════════════

# Access token secret (short-lived tokens, 15 minutes)
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_FOR_ACCESS_TOKENS

# Refresh token secret (long-lived tokens, 7-30 days)
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING_FOR_REFRESH

# ═══════════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════════

# Your portfolio domain (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://sricharan.dev

# Set to 'production' when deploying
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════
# FILE STORAGE — Cloudinary (Free: 25GB storage, 25GB bandwidth)
# Sign up at: https://cloudinary.com
# ═══════════════════════════════════════════════════════════════

# Found in your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Upload preset name (create in Cloudinary: Settings → Upload → Add upload preset)
# Set signing mode to "Unsigned" for direct browser uploads
CLOUDINARY_UPLOAD_PRESET=portfolio_uploads

# ═══════════════════════════════════════════════════════════════
# EMAIL — SMTP for contact form notifications
# Use Gmail App Password, SendGrid, Mailgun, etc.
# For Gmail: https://myaccount.google.com/apppasswords
# ═══════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars

# Your personal email where contact form submissions are sent
CONTACT_EMAIL=sricharan@example.com

# ═══════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════════

# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# GitHub username for GitHub integration (optional)
NEXT_PUBLIC_GITHUB_USERNAME=sricharan

# ═══════════════════════════════════════════════════════════════
# NOTES FOR PRODUCTION DEPLOYMENT ON VERCEL
# ═══════════════════════════════════════════════════════════════
# Add all these variables in Vercel Dashboard:
# Project → Settings → Environment Variables
# 
# Variables starting with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-only (never sent to browser).
